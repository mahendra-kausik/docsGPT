# Copy to .env (git-ignored) and fill in. Never commit real values.

# --- LLM providers ---
GROQ_API_KEY=                 # console.groq.com — workhorse for cheap agent nodes + RAGAS judge
GEMINI_API_KEY=               # aistudio.google.com — final answer synthesis (verify live free-tier limits)

# --- Vector store ---
QDRANT_URL=                   # Qdrant Cloud cluster endpoint (https://...:6333)
QDRANT_API_KEY=               # Qdrant Cloud API key

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# US region: co-located with Qdrant + Cloud Run (both GCP us-central1) — D-044
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Corpus sourcing ---
# Currently UNUSED: corpus is a git clone of langchain-ai/docs (D-016), gold labels come from
# the LangChain Forum via its public no-auth API (D-018). Kept as an optional knob only.
GITHUB_TOKEN=                 # optional; not required by any current ingestion path

# --- Model + retrieval config (can also live in config.yaml) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2  # MiniLM for CPU latency; bge rejected (D-030). Reranker off by default (D-031).
SYNTHESIS_MODEL=gemini/gemini-2.5-flash  # provider-PREFIXED (D-033); 2.0-flash retired 2026-06-01, verify latest Flash in AI Studio (D-020)
CHEAP_MODEL=groq/llama-3.1-8b-instant    # verify exact model id in Groq console
RRF_K=60
RETRIEVE_TOP_K=50
RERANK_TOP_N=6

# --- Deployment (filled at Layer 8) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1                # use a Cloud Run always-free-eligible region
