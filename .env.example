# Copy to .env (git-ignored) and fill in. Never commit real values.

# --- LLM providers ---
GROQ_API_KEY=                 # console.groq.com — workhorse for cheap agent nodes + RAGAS judge
GEMINI_API_KEY=               # aistudio.google.com — final answer synthesis (verify live free-tier limits)

# --- Vector store ---
QDRANT_URL=                   # Qdrant Cloud cluster endpoint (https://...:6333)
QDRANT_API_KEY=               # Qdrant Cloud API key

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Corpus sourcing ---
GITHUB_TOKEN=                 # authenticated GitHub API (5,000 req/hr) for Discussions/Issues

# --- Model + retrieval config (can also live in config.yaml) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
SYNTHESIS_MODEL=gemini-2.5-flash      # 2.0-flash retired 2026-06-01; verify latest 3.x Flash in AI Studio (D-020)
CHEAP_MODEL=groq/llama-3.1-8b-instant # verify exact model id in Groq console
RRF_K=60
RETRIEVE_TOP_K=50
RERANK_TOP_N=6

# --- Deployment (filled at Layer 8) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1                # use a Cloud Run always-free-eligible region
